          "country_code": "Country",
          "password": "[%key:common::config_flow::data::password%]",
          "username": "Account"
        },
        "description": "Tuya BLE requires obtaining encryption key from Tuya cloud. Almost all devices only need to access the cloud once during setup.\n\nRefer to [documentation]({tuya_docs_url}) of Tuya integration to retrieve the cloud credentials.\n\nEnter your Tuya credentials."
      },
      "manual": {
        "data": {
          "address": "MAC address",
          "device_name": "Device name",
          "uuid": "Device UUID",
          "local_key": "Local key",
          "device_id": "Device ID",
          "category": "Category code",
          "product_id": "Product ID",
          "product_name": "Product name",
          "product_model": "Model"
        },
        "data_description": {
          "address": "Bluetooth MAC address in AA:BB:CC:DD:EE:FF format (the `mac` field in a device export)",
          "uuid": "Device UUID (`uuid` field)",
          "local_key": "Encryption key used for BLE communication (`key` field)",
          "device_id": "Tuya cloud device ID (`id` field)",
          "category": "Tuya category code, e.g. `cl` for curtains, `ms` for locks (`category` field)",
          "product_id": "Product ID (`product_id` field)",
          "product_name": "Optional. Product or commercial name (`product_name` field)",
          "product_model": "Optional. Hardware model number (`model` field)"
        },
        "description": "Enter the device credentials. All required fields can be found in a Tuya device export (e.g. from the Tuya IoT platform or a local key extractor tool)."
      }
